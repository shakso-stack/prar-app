# PRAR App environment variables.
#
# VITE_SUPABASE_URL and VITE_SUPABASE_ANON_KEY default to the shared MESPI
# Supabase project (where PRAR Bouquets also lives) if not set, so the
# standard deployment doesn't need a .env file for these.
#
# VITE_BACKEND_URL points at the Render-hosted FastAPI backend used by
# Stages 1 (fetch) and 4–5 (generate/export). Set this in Vercel.

VITE_BACKEND_URL=https://your-render-backend-url.onrender.com
